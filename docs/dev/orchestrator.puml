@startuml
skinparam maxMessageSize 150
skinparam ParticipantPadding 20
skinparam BoxPadding 10

box "Discord Edge (Node.js)" #LightCyan
    participant "Shard Bot" as Bot
end box

queue "NATS JetStream" as NATS

box "Control Plane" #LightPink
    participant "Orchestrator" as Orc
    database "Redis" as Redis
end box

box "Audio Mesh" #LightYellow
    participant "Mixer A" as MixA
    participant "Mixer B" as MixB
end box

== 1. Mixer の稼働報告 (heartbeat / TTL) ==
loop every 5s
    MixA -> NATS : publish mixer.heartbeat\n{id, addr, load}
    MixB -> NATS : publish mixer.heartbeat\n{id, addr, load}
    NATS -> Orc : subscribe mixer.heartbeat
    Orc -> Redis : SET mixers:{id}:status\n{addr, load} EX 10
end

== 2. VC 接続要求と Union 再配置 ==
Bot -> NATS : request vc.request.join\n{unionId, guildId}
NATS -> Orc : deliver join request

Orc -> Redis : GET guilds:{guildId}:unionId
alt guild already assigned to another union
    Orc -> Redis : cleanup old union mapping\nDEL guilds:{guildId}:unionId\nSREM unions:{oldUnionId}:guilds guildId
    alt old union has no remaining guilds
        Orc -> Redis : DEL unions:{oldUnionId}:guilds
        Orc -> Redis : DEL unions:{oldUnionId}:mixerId
        Orc -> NATS : publish mixer.control.{oldMixerId}\n{action: DESTROY_UNION}
    else old union still has members
        Orc -> NATS : publish mixer.control.{oldMixerId}\n{action: UPDATE_UNION, guilds: remainingGuilds}
    end
end

Orc -> Redis : GET unions:{unionId}:mixerId
alt Union に既存 Mixer がある
    Orc -> Redis : GET mixers:{mixerId}:status
    alt Mixer の heartbeat が有効
        Orc -> Redis : reuse mixer assignment
    else Mixer の heartbeat が期限切れ
        Orc -> Redis : DEL unions:{unionId}:mixerId
        Orc -> Redis : choose lowest-load live mixer
        Orc -> Redis : SET unions:{unionId}:mixerId = mixerId
    end
else Union が未割当
    Orc -> Redis : choose lowest-load live mixer
    Orc -> Redis : SET unions:{unionId}:mixerId = mixerId
end

Orc -> Redis : SADD unions:{unionId}:guilds guildId
Orc -> Redis : SET guilds:{guildId}:unionId = unionId
Orc -> NATS : publish mixer.control.{mixerId}\n{action: UPDATE_UNION, guilds: currentGuilds}
Orc --> Bot : reply {mixerAddr}

== 3. 音声データプレーン (UDP) ==
Bot -[#blue]> MixA : UDP notice\n{unionId, guildId, addr}
Bot -[#blue]> MixA : UDP audio\nMAGIC + VERSION + TYPE_AUDIO + unionId + guildId + userId + seq + pcm
MixA -> MixA : receive.notice_accepted / audio_accepted
MixA -> MixA : topology update keeps known guild addresses
MixA -[#green]> Bot : UDP mixed audio (minus-self)

== 4. Leave / cleanup / reassign ==
Bot -> NATS : request vc.request.leave\n{unionId, guildId}
NATS -> Orc : deliver leave request
Orc -> Redis : DEL guilds:{guildId}:unionId
Orc -> Redis : SREM unions:{unionId}:guilds guildId
alt remaining guilds exist
    Orc -> NATS : publish mixer.control.{mixerId}\n{action: UPDATE_UNION, guilds: remainingGuilds}
else union becomes empty
    Orc -> Redis : DEL unions:{unionId}:guilds
    Orc -> Redis : DEL unions:{unionId}:mixerId
    Orc -> NATS : publish mixer.control.{mixerId}\n{action: DESTROY_UNION}
end

note over Orc, Redis
  Redis state model
  - guilds:{guildId}:unionId -> guild の現在所属 Union
  - unions:{unionId}:guilds -> Union に所属する guild Set
  - unions:{unionId}:mixerId -> 担当 Mixer
  - mixers:{mixerId}:status -> heartbeat TTL 情報
end note
@enduml
