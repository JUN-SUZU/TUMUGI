@startuml
skinparam maxMessageSize 180
skinparam ParticipantPadding 18
skinparam BoxPadding 10

participant "Discord VC" as Discord
box "Discord Edge (Node.js)" #LightCyan
    participant "Bot A\n(guild 9777...)" as BotA
    participant "Bot B\n(guild 1309...)" as BotB
end box
queue "NATS JetStream\nControl Plane" as NATS
box "Control Plane" #LightPink
    participant "Orchestrator" as Orc
    database "Redis" as Redis
end box
box "Audio Mesh" #LightYellow
    participant "Mixer\n(Mixer-Rust-1)" as Mixer
end box

== 0. Mixer heartbeat ==
loop every 5s
    Mixer -> NATS : publish mixer.heartbeat\n{id, addr, load}
    NATS -> Orc : subscribe mixer.heartbeat
    Orc -> Redis : SET mixers:{id}:status\n{addr, load} EX 10
end

== 1. Join request / mixer assignment ==
BotA -> NATS : request vc.request.join\n{unionId, guildId}
NATS -> Orc : deliver join request
Orc -> Redis : GET guilds:{guildId}:unionId
alt guild already belongs to another union
    Orc -> Redis : SREM old union guild set\nDEL guilds:{guildId}:unionId
    Orc -> NATS : publish mixer.control.{oldMixerId}\n{action: UPDATE_UNION or DESTROY_UNION}
end

Orc -> Redis : GET unions:{unionId}:mixerId
alt union already has a live mixer
    Orc -> Redis : GET mixers:{mixerId}:status
else union is new or mixer expired
    Orc -> Redis : choose lowest-load live mixer
    Orc -> Redis : SET unions:{unionId}:mixerId = mixerId
end

Orc -> Redis : SADD unions:{unionId}:guilds guildId
Orc -> Redis : SET guilds:{guildId}:unionId = unionId
Orc -> NATS : publish mixer.control.{mixerId}\n{action: UPDATE_UNION, guilds: currentGuilds}
Orc --> BotA : reply {mixerAddr}

BotA -> Discord : joinVoiceChannel()
Discord --> BotA : VoiceConnection Ready
BotA -> Mixer : UDP notice\n{unionId, guildId, addr}

== 2. Audio dataplane ==
Discord -> BotA : user speaking / Opus packets
BotA -> BotA : Opus -> PCM decode
BotA -> Mixer : UDP audio packet\nMAGIC + unionId + guildId + userId + seq + pcm
Mixer -> Mixer : update guild addr on notice/audio receipt
Mixer -> BotA : UDP mixed audio (minus-self)
BotA -> BotA : PCM -> Opus -> play

== 3. Leave request / cleanup ==
BotB -> NATS : request vc.request.leave\n{unionId, guildId}
NATS -> Orc : deliver leave request
Orc -> Redis : DEL guilds:{guildId}:unionId
Orc -> Redis : SREM unions:{unionId}:guilds guildId
alt remaining guilds exist
    Orc -> NATS : publish mixer.control.{mixerId}\n{action: UPDATE_UNION, guilds: remainingGuilds}
else union becomes empty
    Orc -> Redis : DEL unions:{unionId}:guilds
    Orc -> Redis : DEL unions:{unionId}:mixerId
    Orc -> NATS : publish mixer.control.{mixerId}\n{action: DESTROY_UNION}
end

note over Orchestrator, Redis
  Redis key model
  - guilds:{guildId}:unionId -> current union binding
  - unions:{unionId}:guilds -> guild set (Redis Set)
  - unions:{unionId}:mixerId -> assigned mixer
  - mixers:{mixerId}:status -> heartbeat TTL cache (EX 10s)
end note
@enduml
